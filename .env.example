# Copy to .env, then fill in the real (gitignored) values.
# This file is committed as documentation — keep placeholder values only,
# never real secrets.

# ── Drizzle ──────────────────────────────────────────────────────────
# Local Postgres used by Drizzle. Start it with:
#   pnpm run db:start
# Then apply the schema with `pnpm run db:push` (or generate/run migrations
# via `pnpm run db:generate` + `pnpm run db:migrate`).
DATABASE_URL="postgres://root:mysecretpassword@localhost:5433/local"

# In a deployed Worker, Postgres access goes through the "HYPERDRIVE" binding
# (see wrangler.jsonc), not DATABASE_URL — see src/lib/server/db/index.ts.
# For local dev this DATABASE_URL is what's actually used, since resolving
# the Hyperdrive binding falls back to it whenever no live Cloudflare
# context is present.

# SvelteKit's own canonical-origin var (also read as better-auth's baseURL
# below) — same convention @sveltejs/adapter-cloudflare / better-auth expect.
ORIGIN="http://localhost:5173"

# ── Better Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Google OAuth 2.0 Web client — https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:5173/api/auth/callback/google
#   Authorized JS origin:     http://localhost:5173
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Logging ──────────────────────────────────────────────────────────
# App logger (src/lib/server/logger.ts) level: debug | info | warn | error
# (default: info)
# LOG_LEVEL=info

# ── Cloudflare Queues (async job processing) ──────────────────────────
# Required for the "Async Job" demo card (submitHelloJob form action /
# src/lib/server/queue.ts) to enqueue jobs under `vite dev` — without one of
# the two options below, that form action throws immediately (by design —
# see src/lib/server/queue.ts's sendJob).
#
# Option A — local dev, no Cloudflare account needed: point sendJob at
# `wrangler dev`'s default local address for the queue consumer Worker:
QUEUE_LOCAL_PUSH_URL=http://localhost:8787
# Then run `pnpm run queue-worker:dev` (wrangler dev --config
# wrangler.queue.jsonc) in a second terminal — it simulates the
# "hello"/"hello-dlq" queues entirely locally via Miniflare and exposes a
# local-only HTTP endpoint (gated by .dev.vars — copy .dev.vars.example to
# .dev.vars first) that stands in for the real Cloudflare Queues HTTP API.

# Option B — a real Cloudflare account: sendJob pushes via the `cloudflare`
# SDK's queues.messages.push API instead of the local push bridge above.
# Leave QUEUE_LOCAL_PUSH_URL unset (or delete it) for this path.
# One-time setup before a real deploy:
#   npx wrangler queues create hello
#   npx wrangler queues create hello-dlq
# CLOUDFLARE_ACCOUNT_ID="your-account-id"
# CLOUDFLARE_API_TOKEN="your-api-token-with-queues-edit-permission"
# CLOUDFLARE_HELLO_QUEUE_ID="the-hello-queue-id-wrangler-queues-create-prints"
